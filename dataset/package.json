{
  "name": "substrate-dataset",
  "version": "1.0.0",
  "description": "Synthetic dataset generator for Substrate hackathon",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "generate:slack": "node --env-file=.env dist/scripts/gen-slack.js",
    "generate:prs": "node --env-file=.env dist/scripts/gen-prs.js",
    "generate:jira": "node --env-file=.env dist/scripts/gen-jira.js",
    "generate:docs": "node --env-file=.env dist/scripts/gen-docs.js",
    "generate:code": "node --env-file=.env dist/scripts/gen-code.js",
    "generate:all": "npm run generate:slack && npm run generate:prs && npm run generate:jira && npm run generate:docs && npm run generate:code",
    "create-indexes": "node --env-file=.env dist/scripts/create-indexes.js",
    "create-indexes:wait": "node --env-file=.env dist/scripts/create-indexes.js --wait",
    "verify-retrieval": "node --env-file=.env dist/scripts/verify-retrieval.js",
    "ingest": "node --env-file=.env dist/scripts/ingest.js",
    "ingest:dry": "node --env-file=.env dist/scripts/ingest.js --dry-run",
    "reset": "node --env-file=.env dist/scripts/reset-demo.js"
  },
  "dependencies": {
    "mongodb": "^6.8.0",
    "voyageai": "^0.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
