# MongoDB Atlas (sandbox) — get from email link
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=substrate

# AWS Bedrock — for Resolver (Haiku)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_RESOLVER=anthropic.claude-haiku-4-5

# Voyage AI embeddings
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# Optional: dataset loading from S3 (skip if loading from local files)
# DATASET_S3_URI=s3://substrate-demo/acme-robotics/

# LangSmith tracing (optional, sponsor credit)
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=substrate-hackathon

# Server
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000,http://localhost:8081
